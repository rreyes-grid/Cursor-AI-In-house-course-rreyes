FLASK_ENV=development
SECRET_KEY=change-me
JWT_SECRET_KEY=change-me-jwt
DATABASE_URI=sqlite:///ecommerce.db
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
PORT=5004
RATELIMIT_STORAGE_URI=memory://

# Mock payment: frontend sends tok_charge_success or tok_charge_declined
MOCK_PAYMENT_ENABLED=1

# Optional SMTP — if unset, order emails are stored + logged only
# MAIL_SERVER=smtp.example.com
# MAIL_PORT=587
# MAIL_USE_TLS=1
# MAIL_USERNAME=
# MAIL_PASSWORD=
# MAIL_DEFAULT_SENDER=no-reply@example.com
