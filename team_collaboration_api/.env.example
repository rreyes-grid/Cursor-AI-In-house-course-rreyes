FLASK_ENV=development
SECRET_KEY=change-me-in-production-use-long-random-string
JWT_SECRET_KEY=change-me-jwt-secret
DATABASE_URI=sqlite:///team_collab.db
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# Server port (5000 is often taken on macOS by AirPlay; default in run.py is 5001)
PORT=5001

# Optional: Redis for caching, Celery, and Socket.IO message_queue (cross-process emits).
# Uncomment only when redis-server is running; otherwise leave unset — the app will
# fall back to SimpleCache + local Socket.IO, or auto-fallback if Redis is unreachable.
REDIS_URL=redis://127.0.0.1:6379/0

# Celery (point at Redis when using a worker; optional memory broker for dev without Redis)
CELERY_BROKER_URL=redis://127.0.0.1:6379/1
CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/2
CELERY_TASK_ALWAYS_EAGER=false
# When true, notifications use Celery task collab.create_notification (needs broker; worker or eager=true for logs)
USE_ASYNC_NOTIFICATIONS=true
