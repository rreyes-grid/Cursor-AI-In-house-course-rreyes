# Vite frontend — Team Collaboration API base URL (must use VITE_ prefix to expose to client)
VITE_API_URL=http://127.0.0.1:5001

# Customer Support Ticket API (Flask app in customer_support_api/, default port 5002)
VITE_SUPPORT_API_URL=http://127.0.0.1:5002

# Blogging Platform API (Flask app in blogging_api/, default port 5003)
VITE_BLOG_API_URL=http://127.0.0.1:5003

# E-commerce Storefront API (Flask app in ecommerce_api/, default port 5004)
VITE_ECOMMERCE_API_URL=http://127.0.0.1:5004
