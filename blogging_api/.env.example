# Flask
FLASK_ENV=development
SECRET_KEY=change-me-in-production
JWT_SECRET_KEY=change-me-jwt-secret-min-32-chars-recommended

# SQLite (default) or PostgreSQL, etc.
DATABASE_URI=sqlite:///blogging.db

# CORS (comma-separated origins for the Vite dev server or other clients)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Server (default 5003)
PORT=5003

# Redis (optional). Uncomment and start Redis locally (e.g. `brew services start redis`)
# or the app will fall back to in-process SimpleCache if the server is unreachable.
REDIS_URL=redis://127.0.0.1:6379/0
CACHE_DEFAULT_TIMEOUT=120
CACHE_KEY_PREFIX=blog:
